# Infraspine — environment variables
#
# Copy this file to .env.local for local development. Variables prefixed
# NEXT_PUBLIC_ are exposed to the browser (safe for non-secret config only —
# never put real secrets behind that prefix).

# ─── Site configuration (currently wired up) ───────────────────────────────
# Read by lib/site.js, used in app/layout.jsx metadata, components/Navbar.jsx,
# and components/Footer.jsx. If unset, the code falls back to the current
# production values, so none of these are required for the site to work.
NEXT_PUBLIC_SITE_URL=https://www.infraspine.com
NEXT_PUBLIC_CONTACT_PHONE="+92 0308 4847760"
NEXT_PUBLIC_CONTACT_PHONE_TEL=+923001234567
NEXT_PUBLIC_CONTACT_EMAIL=hello@infraspine.com
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567

# ─── SEO / Search Console / Analytics (wired up, all optional) ─────────────
# Read by lib/seo.js. Each one is omitted entirely from the page (no meta
# tag, no script) when left unset — never filled with a placeholder string.
#
# Google Search Console: Settings > Ownership verification > HTML tag method
# — copy just the `content` value of the meta tag it gives you, not the
# whole tag.
GOOGLE_SITE_VERIFICATION=
#
# Bing Webmaster Tools: Settings > Verify ownership > HTML Meta Tag method —
# same idea, just the content value (the msvalidate.01 meta tag).
BING_SITE_VERIFICATION=
#
# Google Analytics 4: Admin > Data Streams > your web stream > Measurement ID=G-PYP2FTP970
# (format: G-XXXXXXXXXX). Must be NEXT_PUBLIC_ since it's read in the browser.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
#
# Google Tag Manager (optional — only needed if you manage tags through GTM
# instead of/in addition to GA4 directly). Format: GTM-XXXXXXX.
NEXT_PUBLIC_GTM_ID=

# ─── Not yet wired up — placeholders for future integrations ───────────────
# Nothing in the code reads these yet. The Contact, Quote, and Booking forms
# (app/contact-us/ContactForm.jsx, app/request-quote/QuoteForm.jsx,
# app/book-meeting/BookingForm.jsx) currently only show a fake success state
# and don't send data anywhere — pick one of these (or another provider) and
# wire it up before relying on the forms for real enquiries.

# Transactional email (e.g. Resend, SendGrid) — to actually deliver form
# submissions to your inbox.
# RESEND_API_KEY=
# CONTACT_FORM_TO_EMAIL=hello@infraspine.com

# CRM (e.g. HubSpot) — if leads from forms should be pushed into a CRM
# HUBSPOT_API_KEY=
